---
import Layout from "../layouts/Layout.astro";

// =====================================================================
// 2 JUNE 2026 SWAP ZONE
// On 2 June 2026 the page flips from waitlist mode (PHASE A)
// to application mode (PHASE B). Edit the three constants below
// and redeploy. Then complete the manual edits listed underneath.
//
// FORM_URL is the GHL embed widget URL. The form ID is the last
// path segment (used for the iframe id and data-form-id attributes,
// which the GHL form_embed.js script needs to wire up auto-resize).
// All "join the waitlist" buttons anchor-scroll to #waitlist where
// the form is embedded inline.
// =====================================================================

const FORM_URL = "https://api.leadconnectorhq.com/widget/form/E4MifGR2pkmg5HWArXwH";
const CTA_TEXT = "Join the Cohort 1 waiting list";
const HERO_EYEBROW = "COHORT 1 · APPLICATIONS OPEN 2 JUNE 2026";

const formId = FORM_URL.split("/").pop() ?? "";

// 2 JUNE 2026 SWAP VALUES (replace the three constants above):
//   const FORM_URL = "https://api.leadconnectorhq.com/widget/form/[APPLICATION-FORM-ID]";
//   const CTA_TEXT = "Apply for Cohort 1";
//   const HERO_EYEBROW = "COHORT 1 · APPLICATIONS NOW OPEN";
//
// PHASE B MANUAL EDITS (search the file for the markers):
//   [PHASE_B_HOW_IT_WORKS] in section 8: delete the waitlist step
//     (current step 1) and renumber the rest. Add the new step 1:
//     "Apply. The application form takes about ten minutes. It asks
//      who you are, what your business does, where you are stuck,
//      and what success looks like. Honest answers are more useful
//      than impressive ones."
//   [PHASE_B_FAQ] in section 10: delete the FAQ item titled
//      "What does joining the waiting list actually do?".
//   [PHASE_B_FINAL_CTA] in section 11: change headline to
//      "Cohort 1. Twelve places. Apply." Replace sub with
//      "Twelve weeks. The Referral Engine, taught from twelve years
//      of practice. Application takes ten minutes."
//      Drop the "Waiting list gets first access" subtext line.
// =====================================================================
---

<Layout>
  <Fragment slot="head">
    <link rel="preload" href={FORM_URL} as="document" crossorigin />
  </Fragment>
  <!-- ============================================================ -->
  <!-- HEADER                                                       -->
  <!-- ============================================================ -->
  <header class="sticky top-0 z-40 bg-paper/85 backdrop-blur border-b border-ink/5">
    <div class="container-page flex items-center justify-between py-4 px-5 md:px-8">
      <a href="#top" class="flex items-center gap-2.5">
        <span class="relative inline-flex">
          <svg width="28" height="28" viewBox="0 0 32 32" aria-hidden="true">
            <circle cx="16" cy="16" r="13" fill="#FF5C3A" />
            <circle cx="16" cy="16" r="5" fill="#FFFFFF" />
            <circle cx="25" cy="9" r="3.5" fill="#FFB547" />
          </svg>
        </span>
        <span class="font-display font-extrabold text-ink text-[1.05rem] tracking-tight">
          The Operator Edge<span class="text-coral">.</span>
        </span>
      </a>
      <a href="#waitlist" class="cta-pill hidden sm:inline-flex" style="padding: 0.7rem 1.1rem; font-size: 0.9rem;">
        {CTA_TEXT}
        <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 12h14m0 0l-6-6m6 6l-6 6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </header>

  <main id="top">
    <!-- ============================================================ -->
    <!-- SECTION 1 · HERO (Option B, A substitute for luck)          -->
    <!-- ============================================================ -->
    <section class="section relative overflow-hidden">
      <!-- Soft brand-tinted background wash -->
      <div class="absolute inset-0 -z-10 bg-paper"></div>
      <div class="absolute -top-32 -right-24 -z-10 w-[28rem] h-[28rem] rounded-full bg-coral/10 blur-3xl"></div>
      <div class="absolute -bottom-40 -left-32 -z-10 w-[26rem] h-[26rem] rounded-full bg-amber/15 blur-3xl"></div>

      <div class="container-page">
        <div class="max-w-3xl">
          <span class="dot-trio mb-7" aria-hidden="true">
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot"></span>
          </span>
          <p class="eyebrow eyebrow-amber mb-4 sm:mb-5">{HERO_EYEBROW}</p>
          <h1 class="headline text-balance text-[3.25rem] sm:text-[4.5rem] md:text-[5.5rem] lg:text-[6.5rem] mb-6">
            A substitute for <span class="headline-coral">luck.</span>
          </h1>
          <p class="text-pretty text-[1.125rem] sm:text-[1.25rem] leading-[1.55] text-ink-soft max-w-2xl mb-9">
            The Referral Programme is a 12-week programme from The Operator Edge that teaches owner-led service businesses how to build a predictable referral pipeline. The Referral Engine behind £1.6m in commissions and 50+ active partners over six years on my own, refined across twelve years of practice, now taught.
          </p>
          <a href="#waitlist" class="cta-pill">
            {CTA_TEXT}
            <svg class="arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 12h14m0 0l-6-6m6 6l-6 6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <p class="mt-5 text-sm text-ink-soft">
            Cohort 1 capped at 12 places. Waiting list gets first access.
          </p>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- SECTION 2 · ABOVE-THE-FOLD PROOF BAR                        -->
    <!-- ============================================================ -->
    <section class="bg-tile">
      <div class="container-page px-5 md:px-8 py-12 md:py-14">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-y-10 gap-x-6">
          <div>
            <div class="font-display font-extrabold tracking-tight text-coral text-[2.5rem] sm:text-[3rem] leading-none mb-2">£1.6m</div>
            <div class="text-sm text-ink-soft leading-snug max-w-[20ch]">in commissions through referral partners, over six years on my own</div>
          </div>
          <div>
            <div class="font-display font-extrabold tracking-tight text-coral text-[2.5rem] sm:text-[3rem] leading-none mb-2">50+</div>
            <div class="text-sm text-ink-soft leading-snug max-w-[18ch]">active referral partner relationships</div>
          </div>
          <div>
            <div class="font-display font-extrabold tracking-tight text-coral text-[2.5rem] sm:text-[3rem] leading-none mb-2">12 years</div>
            <div class="text-sm text-ink-soft leading-snug max-w-[18ch]">of refinement, in practice</div>
          </div>
          <div>
            <div class="font-display font-extrabold tracking-tight text-coral text-[2.5rem] sm:text-[3rem] leading-none mb-2">Zero</div>
            <div class="text-sm text-ink-soft leading-snug max-w-[18ch]">spent on cold outreach</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- SECTION 3 · THE PROBLEM (Hiding in plain sight)              -->
    <!-- ============================================================ -->
    <section class="section bg-paper">
      <div class="container-page">
        <div class="max-w-3xl">
          <p class="eyebrow eyebrow-amber mb-4">THE PATTERN</p>
          <h2 class="headline text-balance text-[2.5rem] sm:text-[3.25rem] md:text-[4rem] mb-8">
            Hiding in <span class="headline-coral">plain sight.</span>
          </h2>
          <div class="space-y-5 text-[1.0625rem] sm:text-[1.125rem] leading-[1.65] text-ink-soft text-pretty">
            <p>Most growth advice for service businesses asks you to do something uncomfortable. Cold email. Cold DMs. LinkedIn outreach. Paid ads. SEO content treadmills.</p>
            <p>You&rsquo;ve tried it. You know how it goes. Reply rates collapse, cost-per-lead climbs, and the brand grinds down with every &ldquo;just following up&rdquo; message that goes nowhere.</p>
            <p class="text-ink font-medium">Meanwhile, every trust-based business in the country quietly grows the same way it always has.</p>
          </div>

          <ul class="list-coral mt-8 mb-10 text-[1.0625rem] sm:text-[1.125rem] leading-[1.55] text-ink">
            <li>Doctors refer patients to specialists.</li>
            <li>Solicitors refer clients to barristers.</li>
            <li>Estate agents introduce buyers to mortgage brokers.</li>
            <li>Accountants introduce business owners to wealth managers.</li>
            <li>Hairdressers refer to colourists.</li>
            <li>Dentists refer to orthodontists.</li>
            <li>Architects refer to structural engineers.</li>
          </ul>

          <div class="space-y-5 text-[1.0625rem] sm:text-[1.125rem] leading-[1.65] text-ink-soft text-pretty">
            <p>The whole professional services economy runs on it. It has done for centuries.</p>
            <p>It is so familiar that no one names it as a system. The same engine, in different costumes, dressed differently for the modern internet: Amazon affiliates. Brand ambassadors. Recruitment referral fees. SaaS partner programmes. Vogue&rsquo;s #gifted economy. Every time someone with trusted access to an audience introduces a service or product into that audience, the engine is running.</p>
            <p class="text-ink font-medium">Every trust business runs on this engine. Most just never engineered theirs deliberately.</p>
            <p class="font-display font-extrabold text-ink text-[1.5rem] sm:text-[1.875rem] tracking-tight pt-3">
              That&rsquo;s the <span class="text-coral">gap.</span>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- SECTION 4 · THE MECHANISM (The Referral Engine)              -->
    <!-- ============================================================ -->
    <section class="section bg-tile">
      <div class="container-page">
        <div class="max-w-3xl mb-10 md:mb-14">
          <p class="eyebrow eyebrow-amber mb-4">THE METHOD</p>
          <h2 class="headline text-balance text-[2.5rem] sm:text-[3.25rem] md:text-[4rem] mb-6">
            The Referral <span class="headline-coral">Engine.</span>
          </h2>
          <p class="text-[1.25rem] sm:text-[1.5rem] font-display font-bold text-ink mb-6 leading-tight tracking-tight">
            Five steps. Twelve years to build. Twelve weeks to teach.
          </p>
          <p class="text-[1.0625rem] sm:text-[1.125rem] leading-[1.65] text-ink-soft text-pretty">
            The Referral Engine is the named method behind every cohort of The Referral Programme. It&rsquo;s how you turn the engine that&rsquo;s already running everywhere into one you operate on purpose, in your own market, with your own trust capital.
          </p>
        </div>

        <ol class="grid gap-5 md:gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              n: "01",
              t: "Identify the right referral partners.",
              b: "Not networking, not “warm intros.” A specific commercial relationship with the people already speaking to your future clients at the trigger moment.",
            },
            {
              n: "02",
              t: "Position yourself correctly.",
              b: "How you show up before, during, and after a referral conversation is the difference between being recommended and being mentioned. There is a structural way to do this; it isn’t personality-based.",
            },
            {
              n: "03",
              t: "Build relationships.",
              b: "Most referral partnerships die in the gap between “good chat” and “first referral.” This module exists because that gap is engineerable, not down to luck or chemistry.",
            },
            {
              n: "04",
              t: "Activate referrals.",
              b: "Signed agreements don’t generate referrals. Specific behaviours do. Some are commercial; others, surprisingly, are not.",
            },
            {
              n: "05",
              t: "Systemise and scale.",
              b: "What runs on instinct in your first three relationships needs to run on a system by your tenth. The programme delivers a Notion-based operating system that does this for you.",
            },
          ].map((step) => (
            <li class="card flex flex-col gap-3 bg-paper border border-ink/5">
              <div class="flex items-baseline gap-3">
                <span class="font-display font-extrabold text-coral text-[1.625rem] tracking-tight">{step.n}</span>
                <span class="dot bg-amber" aria-hidden="true" style="background: var(--color-amber);"></span>
              </div>
              <h3 class="font-display font-extrabold text-ink text-[1.15rem] tracking-tight leading-snug" set:html={step.t}></h3>
              <p class="text-[0.975rem] leading-[1.6] text-ink-soft text-pretty" set:html={step.b}></p>
            </li>
          ))}
        </ol>

        <p class="max-w-3xl mt-10 md:mt-14 text-[0.975rem] sm:text-[1rem] leading-[1.65] text-ink-soft italic text-pretty">
          The model is universal across trust-based service categories. The proof anchors in financial services because that&rsquo;s where it was built; the application is anywhere it works.
        </p>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- SECTION 5 · THE PROOF (numbers, case studies, testimonials)  -->
    <!-- ============================================================ -->
    <section class="section bg-paper">
      <div class="container-page">
        <div class="max-w-3xl mb-12">
          <p class="eyebrow eyebrow-amber mb-4">THE EVIDENCE</p>
          <h2 class="headline text-balance text-[2.5rem] sm:text-[3.25rem] md:text-[4rem] mb-6">
            Twelve years of practice. Numbers that <span class="headline-coral">hold up.</span>
          </h2>
          <p class="text-[1.0625rem] sm:text-[1.125rem] leading-[1.65] text-ink-soft text-pretty">
            The Referral Programme isn&rsquo;t a theoretical course. It teaches the playbook I&rsquo;ve been running since 2014 in private medical insurance, one of the most cynical, regulated, and fee-allergic markets in the UK. Two case studies, then two people who actually refer to me.
          </p>
        </div>

        <!-- Case studies -->
        <div class="grid gap-6 md:grid-cols-2 mb-14 md:mb-20">
          <article class="card bg-tile border border-ink/5">
            <p class="eyebrow eyebrow-teal mb-3" style="color: var(--color-teal);">CASE STUDY 1</p>
            <h3 class="font-display font-extrabold text-ink text-[1.4rem] sm:text-[1.5rem] tracking-tight leading-snug mb-4">
              Engineered <span class="text-coral">partnership.</span>
            </h3>
            <p class="text-[1rem] leading-[1.65] text-ink-soft text-pretty">
              A general insurance broker I now consider one of my closest friends. Introduced through my accountant, structured as a fair income split, the relationship has been nurtured through golf, dinners, and reciprocal value over a decade. The override structure built into the agreement means he&rsquo;s incentivised to introduce me to other potential referral partners, and he has done. Every part of this was deliberate. None of it was networking.
            </p>
          </article>
          <article class="card bg-tile border border-ink/5">
            <p class="eyebrow eyebrow-teal mb-3" style="color: var(--color-teal);">CASE STUDY 2</p>
            <h3 class="font-display font-extrabold text-ink text-[1.4rem] sm:text-[1.5rem] tracking-tight leading-snug mb-4">
              Zero commission, sustained <span class="text-coral">referrals.</span>
            </h3>
            <p class="text-[1rem] leading-[1.65] text-ink-soft text-pretty">
              A PA I met when we were both starting out. She&rsquo;s now built that into a firm with twenty-five PAs serving ultra-high-net-worth individuals, including names you would recognise. Over the relationship&rsquo;s lifetime she&rsquo;s generated more than £200,000 in income for me. She has never once taken a commission, override, or fee. She refers because the outcomes are good and the service standards match her clients&rsquo;. This is the proof that the engine isn&rsquo;t financial; it&rsquo;s reciprocal value, of which money is sometimes one component and never the engine.
            </p>
          </article>
        </div>

        <!-- Testimonials header -->
        <div class="max-w-3xl mb-8 md:mb-10">
          <h3 class="font-display font-extrabold text-ink text-[1.625rem] sm:text-[2rem] tracking-tight leading-tight">
            What people who actually refer to me <span class="text-coral">say.</span>
          </h3>
        </div>

        <!-- Testimonials grid (cream-on-cream style). Narrower container so cards read smaller on the page. -->
        <div class="max-w-[58rem] mx-auto grid gap-6 md:gap-7 md:grid-cols-2">

          <!-- Testimonial 1 -->
          <figure class="testimonial-card">
            <div class="flex items-start justify-between mb-4">
              <span class="testimonial-quote" aria-hidden="true">&ldquo;</span>
              <span class="dot-trio mt-3" aria-hidden="true">
                <span class="dot"></span>
                <span class="dot"></span>
                <span class="dot"></span>
              </span>
            </div>
            <blockquote class="testimonial-body">
              <p>Matt is our go-to for all our own and our clients&rsquo; private medical needs. Over my career I have worked with numerous private medical experts, but Matt&rsquo;s knowledge of products and the market is unrivalled.</p>
              <p>Above all, I feel 100% confident recommending our clients to Matt because his honesty and integrity shine through in abundance, and he always has the client&rsquo;s best interests as his number one priority.</p>
            </blockquote>
            <div class="testimonial-divider"></div>
            <figcaption class="flex items-center gap-3.5">
              <span class="testimonial-avatar">RC</span>
              <span>
                <span class="block testimonial-name">Robert C.</span>
                <span class="block testimonial-role">Director, Head of Growth / Chartered Financial Planner</span>
              </span>
            </figcaption>
          </figure>

          <!-- Testimonial 2 -->
          <figure class="testimonial-card">
            <div class="flex items-start justify-between mb-4">
              <span class="testimonial-quote" aria-hidden="true">&ldquo;</span>
              <span class="dot-trio mt-3" aria-hidden="true">
                <span class="dot"></span>
                <span class="dot"></span>
                <span class="dot"></span>
              </span>
            </div>
            <blockquote class="testimonial-body">
              <p>At annabel, it&rsquo;s essential that we only refer our clients to third parties we trust implicitly, those who offer a highly personal, practical and cost-conscious service. Healthcare cover can often feel complex and overwhelming, but Matt Howells and his team at Vizion consistently go above and beyond to make the process clear and manageable. Matt has been a preferred supplier of annabel for over 10 years, and his expertise, responsiveness and genuine care mean our clients always feel informed, supported and, most importantly, appropriately insured.</p>
            </blockquote>
            <div class="testimonial-divider"></div>
            <figcaption class="flex items-center gap-3.5">
              <span class="testimonial-avatar">AB</span>
              <span>
                <span class="block testimonial-name">Annabel B.</span>
              </span>
            </figcaption>
          </figure>

        </div>

        <div class="mt-14 md:mt-16 flex flex-col items-center text-center">
          <a href="#waitlist" class="cta-pill">
            {CTA_TEXT}
            <svg class="arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 12h14m0 0l-6-6m6 6l-6 6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <p class="mt-4 text-sm text-ink-soft">Cohort 1 capped at 12 places. Waiting list gets first access.</p>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- SECTION 6 · THE PROGRAMME                                    -->
    <!-- ============================================================ -->
    <section class="section bg-tile">
      <div class="container-page">
        <div class="max-w-3xl mb-10 md:mb-14">
          <p class="eyebrow eyebrow-amber mb-4">THE PROGRAMME</p>
          <h2 class="headline text-balance text-[2.5rem] sm:text-[3.25rem] md:text-[4rem] mb-6">
            Twelve weeks. Six modules. One <span class="headline-coral">operating system.</span>
          </h2>
          <p class="text-[1.25rem] sm:text-[1.5rem] font-display font-bold text-ink mb-6 leading-tight tracking-tight text-pretty">
            A working pipeline by week twelve. Not a finished course you watch and shelve.
          </p>
          <p class="text-[1.0625rem] sm:text-[1.125rem] leading-[1.65] text-ink-soft text-pretty">
            The Referral Programme is built around real-world implementation, not consumption. By the end of week twelve you have an operating system, a partnership map, signed agreements, and a working pipeline. Not knowledge. Infrastructure.
          </p>
        </div>

        <!-- Six modules -->
        <div class="bg-paper rounded-3xl border border-ink/5 p-6 md:p-10 mb-10">
          <h3 class="font-display font-extrabold text-ink text-[1.25rem] tracking-tight mb-2">The six modules</h3>
          <div class="mt-3">
            {[
              { n: "Module 1", w: "Weeks 1–2", t: "Foundations.", b: "Are you actually referable? A diagnostic that most service businesses fail the first time they take it honestly." },
              { n: "Module 2", w: "Weeks 3–4", t: "The Partnership Map.", b: "Identifying who is speaking to your client at the trigger moment. The output is your live partnership map for the next twelve months." },
              { n: "Module 3", w: "Weeks 5–6", t: "Approach & Positioning.", b: "How to present yourself so referral partners want to refer. Scripts, frames, mistakes to avoid." },
              { n: "Module 4", w: "Weeks 7–8", t: "The Commercial Structure.", b: "Income splits, override structures, agreements. Reading partner motivation. When money is part of it and when it isn’t." },
              { n: "Module 5", w: "Weeks 9–10", t: "Relationship Building.", b: "Turning a signed agreement into actual referrals. Where most partnerships die." },
              { n: "Module 6", w: "Weeks 11–12", t: "The System.", b: "A Notion-based operating system you’ll have built across the previous five modules, formalised here and ready to scale." },
            ].map((m) => (
              <div class="module-row">
                <div>
                  <div class="module-num">{m.n}</div>
                  <div class="text-xs text-ink-soft tracking-wide mt-0.5" set:html={m.w}></div>
                </div>
                <div>
                  <h4 class="font-display font-extrabold text-ink text-[1.1rem] tracking-tight leading-snug mb-1.5" set:html={m.t}></h4>
                  <p class="text-[0.975rem] leading-[1.6] text-ink-soft text-pretty" set:html={m.b}></p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Inside the cohort + What it asks of you -->
        <div class="grid gap-6 md:grid-cols-2">
          <div class="bg-paper rounded-3xl border border-ink/5 p-6 md:p-8">
            <h3 class="font-display font-extrabold text-ink text-[1.25rem] tracking-tight mb-4">
              Inside the cohort
            </h3>
            <ul class="list-coral text-[0.975rem] leading-[1.55] text-ink">
              <li>Six modules of structured teaching content (video, written lessons, exercises, templates)</li>
              <li>A weekly live group coaching call across all twelve weeks</li>
              <li>Two 1:1 check-ins with me at milestone points in the programme</li>
              <li>Peer accountability pods inside Skool, deliberately cross-vertical so cohort members become each other&rsquo;s referral partners once the programme ends</li>
              <li>A complete Notion operating system, yours to keep</li>
              <li>Lifetime access to all programme materials</li>
              <li>One month of The Operator Network included with the cohort fee, then optional monthly subscription to stay inside an active network of programme alumni building referral partnerships in their respective markets</li>
            </ul>
          </div>
          <div class="bg-paper rounded-3xl border border-ink/5 p-6 md:p-8">
            <h3 class="font-display font-extrabold text-ink text-[1.25rem] tracking-tight mb-4">
              What it asks of you
            </h3>
            <p class="text-[1rem] leading-[1.65] text-ink-soft text-pretty">
              Sixty to ninety hours of engaged work across twelve weeks. Roughly five to seven hours a week. That&rsquo;s a real commitment, and the programme is built to be incompatible with skimming. Lessons require evidence and outputs, not just completion clicks. Members come out of the programme with a working system, not a watched course.
            </p>
          </div>
        </div>

        <div class="mt-14 md:mt-16 flex flex-col items-center text-center">
          <a href="#waitlist" class="cta-pill">
            {CTA_TEXT}
            <svg class="arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 12h14m0 0l-6-6m6 6l-6 6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <p class="mt-4 text-sm text-ink-soft">Cohort 1 capped at 12 places. Waiting list gets first access.</p>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- SECTION 7 · WHO IT'S FOR                                     -->
    <!-- ============================================================ -->
    <section class="section bg-paper">
      <div class="container-page">
        <div class="max-w-3xl mb-10">
          <h2 class="headline text-balance text-[2.5rem] sm:text-[3.25rem] md:text-[4rem] mb-6">
            Who this is <span class="headline-coral">for.</span>
          </h2>
          <div class="space-y-5 text-[1.0625rem] sm:text-[1.125rem] leading-[1.65] text-ink-soft text-pretty">
            <p>The Operator Edge is for owner-led, trust-based service professionals at least two years into running their own business. The model needs existing clients and an established service offering to compound on.</p>
